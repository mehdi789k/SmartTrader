# متغیرهای محیطی برای Backend
# Environment variables for Smart Tred API

# Secret key for JWT tokens (change this in production)
SECRET_KEY=your-super-secret-key-change-this-in-production

# Algorithm for JWT
ALGORITHM=HS256

# Token expiration time (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MetaTrader5 settings
MT5_PATH=
MT5_TIMEOUT=5000
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=LiteFinance-MT5-Demo

# API settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# CORS origins (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/smarttred.log

# Database (for future use)
DATABASE_URL=sqlite:///./smarttred.db
